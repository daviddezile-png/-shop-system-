// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  email     String?  @unique
  phone     String?
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]   @relation("UserSales")
  loans     Loan[]   @relation("UserLoans")
}

enum Role {
  ADMIN
  STAFF
}

model Product {
  id           String     @id @default(cuid())
  name         String     @unique
  buyingPrice  Float
  sellingPrice Float
  category     String?    
  scale        String?   

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory Inventory?
  sales     Sale[]
  loans     Loan[]
}

model Inventory {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String   @unique
  quantity  Int
  scale     String?  

  updatedAt DateTime @updatedAt
}

model Sale {
  id        String       @id @default(cuid())
  product   Product      @relation(fields: [productId], references: [id])
  productId String

  soldBy    User         @relation("UserSales", fields: [soldById], references: [id])
  soldById  String       // staff/admin who made the sale

  quantity     Int
  totalPrice   Float
  paymentType  PaymentType
  createdAt    DateTime @default(now())
  scale        String?   
}

enum PaymentType {
  CASH
  ONLINE
}

model Loan {
  id           String       @id @default(cuid())
  product      Product      @relation(fields: [productId], references: [id])
  productId    String

  createdBy    User         @relation("UserLoans", fields: [createdById], references: [id])
  createdById  String       // staff/admin who created the loan

  customerName String
  phone        String
  quantity     Int
  loanQuantity Int          
  paymentStatus PaymentStatus @default(NOT_PAID)
  paymentType   PaymentType? // only required if status = PAID

  createdAt DateTime @default(now())
  scale     String?   
}

enum PaymentStatus {
  PAID
  NOT_PAID
}
